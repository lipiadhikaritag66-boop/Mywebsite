  <!-- HISTORY TIMELINE -->
  <section class="section-pad">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Our Journey</span>
        <h2>Milestones &amp; Achievements</h2>
      </div>
      <div style="max-width:700px;margin:0 auto;" class="timeline">
        <div class="timeline-item"><span class="timeline-date">2001</span><h4>HIMT Founded</h4><p>Established with BBA and Economics programs with 120 students in Lalitpur, affiliated to Tribhuvan University.</p></div>
        <div class="timeline-item"><span class="timeline-date">2005</span><h4>BIM Program Launched</h4><p>Became one of the first private colleges in Nepal to offer the Bachelor of Information Management program.</p></div>
        <div class="timeline-item"><span class="timeline-date">2008</span><h4>MBA Program Introduced</h4><p>Postgraduate MBA program launched to serve working professionals seeking advanced management education.</p></div>
        <div class="timeline-item"><span class="timeline-date">2010</span><h4>BSc.CSIT Added &amp; New Campus</h4><p>Computer Science program launched. New modern campus building inaugurated with improved labs and library.</p></div>
        <div class="timeline-item"><span class="timeline-date">2015</span><h4>2000+ Students Milestone</h4><p>Student enrolment crossed 2,000. 80+ industry partnerships established for internship and placement programs.</p></div>
        <div class="timeline-item"><span class="timeline-date">2020</span><h4>Digital Infrastructure Upgrade</h4><p>Launched e-learning platform, upgraded computer labs to 80+ systems, and introduced digital library access.</p></div>
        <div class="timeline-item"><span class="timeline-date">2024</span><h4>Best College Award – TU</h4><p>Received the prestigious Best Affiliated College award from Tribhuvan University for academic excellence and infrastructure.</p></div>
      </div>
    </div>
  </section>

